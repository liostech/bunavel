# Application
APP_NAME=Bunavel
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000

# Database
DB_DRIVER=sqlite
DB_FILENAME=./storage/database.sqlite

# Security
APP_KEY=your-secret-key-here

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
